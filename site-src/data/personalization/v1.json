      },
      {
        "id": "career",
        "label": "求职准备",
        "description": "在共同课程之外，逐阶段加入机考、项目证据和面试表达。"
      }
    ],
    "dimensions": [
      { "id": "engineering_tools", "label": "工程工具", "descriptions": ["需要从文件、终端和 Git 的首次操作开始", "能完成部分操作，但仍需要结构化补修", "能独立使用终端、编辑器和本地 Git 闭环"] },
      { "id": "programming", "label": "编程基础", "descriptions": ["需要从变量、分支、循环和首次运行开始", "能阅读和修改基础程序", "能组织函数、定位常见错误并验证结果"] },
