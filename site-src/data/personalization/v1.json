          { "id": "locate", "label": "会看最后几行、定位行号并尝试修复", "score": 1, "evidence": "已经能完成常见错误定位" },
          { "id": "isolate", "label": "会构造最小输入、验证假设并补回归测试", "score": 2, "evidence": "具备结构化排错和回归意识" }
        ]
      },
      {
        "id": "algorithms-structure",
        "dimension": "algorithms_cs",
        "question": "需要按进入顺序处理任务时，你会怎样选择数据结构？",
        "options": [
          { "id": "unknown", "label": "我还不了解栈、队列或集合的区别", "score": 0, "evidence": "需要建立常见数据结构的用途认知" },
          { "id": "queue", "label": "会优先想到队列，并能说明先进先出", "score": 1, "evidence": "能够把问题特征映射到基础数据结构" },
          { "id": "tradeoff", "label": "会比较队列实现、复杂度和边界输入", "score": 2, "evidence": "能够从结构、复杂度和边界共同判断" }
        ]
      },
      {
        "id": "algorithms-complexity",
        "dimension": "algorithms_cs",
        "question": "同一个列表被重复完整扫描很多次，你会关注什么？",
        "options": [
