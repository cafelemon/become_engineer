          { "id": "loops", "label": "会检查循环次数和是否能减少重复扫描", "score": 1, "evidence": "已经能识别基础性能问题" },
          { "id": "measure", "label": "会分析时间空间复杂度，并用不同规模输入验证", "score": 2, "evidence": "具备复杂度分析和实验验证意识" }
        ]
      },
      {
        "id": "project-tests",
        "dimension": "project_engineering",
        "question": "你说“项目功能完成了”时，通常能提供什么证据？",
        "options": [
          { "id": "screenshot", "label": "主要是截图或口头说明", "score": 0, "evidence": "需要建立可重复运行和验收证据" },
          { "id": "commands", "label": "有运行命令、输入输出和几个测试", "score": 1, "evidence": "已经开始使用可复现证据" },
          { "id": "regression", "label": "有自动测试、失败路径、环境说明和回归记录", "score": 2, "evidence": "具备较完整的工程验收习惯" }
        ]
      },
      {
        "id": "project-structure",
        "dimension": "project_engineering",
        "question": "一个小程序开始变长时，你通常怎样继续维护？",
