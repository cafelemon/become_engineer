    ],
    "questions": [
      {
        "id": "tools-terminal",
        "dimension": "engineering_tools",
        "question": "课程让你“打开终端并确认当前目录”，你最接近哪种情况？",
        "options": [
          { "id": "unknown", "label": "我不确定终端是什么或在哪里打开", "score": 0, "evidence": "需要补齐终端的寻找、打开和首次确认步骤" },
          { "id": "open", "label": "我能打开 Terminal、PowerShell 或编辑器终端", "score": 1, "evidence": "已经认识终端，但目录与命令验证仍需练习" },
          { "id": "verify", "label": "我会用 pwd/Get-Location、cd 和 ls/dir 确认位置", "score": 2, "evidence": "能够独立完成终端目录闭环" }
        ]
      },
      {
        "id": "tools-git",
        "dimension": "engineering_tools",
        "question": "关于本地 Git 仓库和 GitHub，哪句话最符合你的理解？",
        "options": [
          { "id": "linked", "label": "执行 git init 后应该会自动连接 GitHub", "score": 0, "evidence": "需要区分本地仓库、远程仓库和连接动作" },
          { "id": "local", "label": "我做过本地提交，但 remote、push 或认证还不熟", "score": 1, "evidence": "本地 Git 有基础，远程协作需要补修" },
          { "id": "remote", "label": "我能解释 remote，并完成 add、commit、push 和 clone", "score": 2, "evidence": "具备本地到远程的基本版本管理能力" }
        ]
      },
      {
        "id": "programming-flow",
        "dimension": "programming",
        "question": "看到变量、if 和 for 组成的一小段 Python，你通常能做到什么？",
        "options": [
          { "id": "unreadable", "label": "大多看不懂，也不知道从哪里运行", "score": 0, "evidence": "需要从首次运行和基本语法开始" },
          { "id": "predict", "label": "能大致说出输出，并修改一个条件或循环", "score": 1, "evidence": "已经具备阅读和主动修改基础程序的能力" },
          { "id": "explain", "label": "能解释执行顺序、边界，并写测试验证", "score": 2, "evidence": "基础控制流和验证能力较稳定" }
        ]
      },
      {
        "id": "programming-debug",
        "dimension": "programming",
        "question": "程序出现 ValueError 或 TypeError 时，你通常怎么处理？",
        "options": [
